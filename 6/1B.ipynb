   "source": [
    "import xmlrpc.client\n",
    "server = xmlrpc.client.ServerProxy(\"http://localhost:1234/\")\n",
    "\n",
    "num = int(input(\"Enter a number: \"))\n",
    "result = server.factorial(num)\n",
    "print(\"Factorial received from server:\", result)"
